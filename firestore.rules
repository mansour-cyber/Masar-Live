rules_version = '2';
// ============================================================
// قواعد أمان Firestore لمنصة مسار
// المبدأ: كل مستخدم يصل فقط إلى بياناته. لا وصول بدون مصادقة.
// انشرها من: Firebase Console → Firestore → Rules → Publish
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function owns(resource) {
      return signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    // ملفات المستخدمين (اختياري للمرحلة القادمة)
    match /users/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    // العمليات: القراءة/التعديل/الحذف لمالكها فقط
    match /projects/{projectId} {
      allow read, update, delete: if owns(resource);
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 120;
    }

    // منع أي مسار آخر افتراضيًا
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
